generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

///////////////////////////
// ENUMS
///////////////////////////

enum Role {
  USER
  ADMIN
  EDITOR
}

enum PostStatus {
  DRAFT
  REVIEW
  PUBLISHED
  ARCHIVED
}

enum SubscriptionStatus {
  ACTIVE
  CANCELED
  EXPIRED
  PENDING
}

enum PaymentProvider {
  MERCADO_PAGO
  STRIPE
}

enum ClassifiedStatus {
  PENDING_REVIEW
  APPROVED
  REJECTED
  SUSPENDED
}

enum ClassifiedType {
  PRODUCT
  SERVICE
  JOB
}

///////////////////////////
// USER
///////////////////////////

model User {
  id            String   @id @default(uuid())
  name          String
  email         String   @unique
  passwordHash  String
  role          Role     @default(USER)
  city          String?
  state         String?
  createdAt     DateTime @default(now())

  subscription  Subscription?
  posts         Post[]
  favorites     Favorite[]
  classifieds   Classified[]
  alerts        Alert[]

  @@map("users")
}

///////////////////////////
// SUBSCRIPTION
///////////////////////////

model Subscription {
  id              String   @id @default(uuid())
  userId          String   @unique
  plan            String
  status          SubscriptionStatus
  nextBilling     DateTime?
  provider        PaymentProvider
  providerRef     String?
  createdAt       DateTime @default(now())

  user            User     @relation(fields: [userId], references: [id])
  payments        Payment[]

  @@map("subscriptions")
}

///////////////////////////
// PAYMENT
///////////////////////////

model Payment {
  id              String   @id @default(uuid())
  subscriptionId  String
  amount          Float
  status          String
  provider        PaymentProvider
  providerRef     String?
  createdAt       DateTime @default(now())

  subscription    Subscription @relation(fields: [subscriptionId], references: [id])

  @@map("payments")
}

///////////////////////////
// POSTS (NOTÍCIAS)
///////////////////////////

model Post {
  id               String      @id @default(uuid())
  title            String
  subtitle         String?
  content          String
  seoTitle         String?
  seoDescription   String?
  source           String?
  sourceUrl        String?
  confidenceScore  Float?
  status           PostStatus  @default(DRAFT)
  region           String?
  category         String?
  tags             String[]
  metadata         Json?

  isPremium        Boolean     @default(false)

  publishedAt      DateTime?
  createdAt        DateTime    @default(now())

  authorId         String?
  author           User?       @relation(fields: [authorId], references: [id])

  favorites        Favorite[]
  analytics        AnalyticsEvent[]

  @@map("posts")
}

///////////////////////////
// FAVORITOS
///////////////////////////

model Favorite {
  id        String   @id @default(uuid())
  userId    String
  postId    String
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id])
  post      Post     @relation(fields: [postId], references: [id])

  @@unique([userId, postId])
  @@map("favorites")
}

///////////////////////////
// CLASSIFICADOS
///////////////////////////

model Classified {
  id          String           @id @default(uuid())
  userId      String
  type        ClassifiedType
  title       String
  description String
  price       Float?
  city        String?
  contact     String?
  images      String[]
  status      ClassifiedStatus @default(PENDING_REVIEW)

  createdAt   DateTime         @default(now())

  user        User             @relation(fields: [userId], references: [id])

  @@map("classifieds")
}

///////////////////////////
// ALERTAS (CLIMA/TRÂNSITO)
///////////////////////////

model Alert {
  id        String   @id @default(uuid())
  userId    String
  type      String
  content   String
  region    String?
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id])

  @@map("alerts")
}

///////////////////////////
// ANALYTICS
///////////////////////////

model AnalyticsEvent {
  id        String   @id @default(uuid())
  userId    String?
  postId    String?
  event     String
  data      Json?
  createdAt DateTime @default(now())

  post      Post?    @relation(fields: [postId], references: [id])

  @@map("analytics_events")
}

///////////////////////////
// IA TRACKING
///////////////////////////

model AIProcessingLog {
  id        String   @id @default(uuid())
  type      String   // IA1, IA2, IA3
  input     Json
  output    Json?
  status    String
  createdAt DateTime @default(now())

  @@map("ai_logs")
}

///////////////////////////
// FEATURE FLAGS / EXPERIMENTOS
///////////////////////////

model FeatureFlag {
  id        String   @id @default(uuid())
  name      String   @unique
  enabled   Boolean  @default(false)
  config    Json?
  createdAt DateTime @default(now())

  @@map("feature_flags")
}